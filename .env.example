# Cloud Data Integration
VITE_CLOUD_DATA_URL="https://docs.google.com/spreadsheets/d/your-id/gviz/tq?tqx=out:json"

# Jira Cloud API
JIRA_API_TOKEN="seu-token-aqui"
JIRA_USER_EMAIL="seu-email@exemplo.com"
JIRA_BASE_URL="https://sua-empresa.atlassian.net"

# Upstash Redis (Vercel KV) — usadas pela serverless function /api/comments
# Adicionar no painel Vercel: Settings > Environment Variables
# Ou vincular um Vercel KV store ao projeto (as vars são criadas automaticamente)
KV_REST_API_URL="https://seu-endpoint.upstash.io"
KV_REST_API_TOKEN="seu-token-aqui"

# Dev local — proxy de /api/* para a URL abaixo durante `npm run dev`
# Use a URL deployada do Vercel para testar com a API real localmente
# Exemplo: VITE_API_URL="https://locavia-dashboard.vercel.app"
# Deixe em branco para usar http://localhost:3000 (vercel dev)
VITE_API_URL=""

# ── Gate de login (senha única) — /api/login ──────────────────────────────
# Se AMBAS estiverem setadas, o painel exige senha e as APIs checam sessão.
# Se faltarem (dev/local), o gate fica DESATIVADO (tudo aberto, como antes).
# SESSION_SECRET: string aleatória longa para assinar o cookie de sessão (HMAC).
SESSION_SECRET=""
# DASHBOARD_PASSWORD: a senha de acesso ao painel (vive só no servidor).
DASHBOARD_PASSWORD=""

# Origem permitida no CORS do /api/comments (a URL do dashboard). Sem isso, chamadas
# cross-origin são bloqueadas (same-origin segue funcionando). Ex.: https://locavia-dashboard.vercel.app
ALLOWED_ORIGIN=""

# ── Botão "Atualizar agora" — /api/refresh dispara o sync no GitHub Actions ──
# Token GitHub (fine-grained PAT) com permissão Actions: Read/Write no repo. Só no servidor.
GITHUB_DISPATCH_TOKEN=""
# Repositório no formato "owner/repo" (ex.: minha-org/locavia-dashboard).
GITHUB_REPO=""
# (Opcionais) workflow e branch alvo do dispatch.
GITHUB_WORKFLOW="hourly-sync.yml"
GITHUB_REF="main"
