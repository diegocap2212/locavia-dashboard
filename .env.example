# Cloud Data Integration
VITE_CLOUD_DATA_URL="https://docs.google.com/spreadsheets/d/your-id/gviz/tq?tqx=out:json"

# Jira Cloud API
JIRA_API_TOKEN="seu-token-aqui"
JIRA_USER_EMAIL="seu-email@exemplo.com"
JIRA_BASE_URL="https://sua-empresa.atlassian.net"

# Upstash Redis (Vercel KV) — usadas pela serverless function /api/comments
# Adicionar no painel Vercel: Settings > Environment Variables
# Ou vincular um Vercel KV store ao projeto (as vars são criadas automaticamente)
KV_REST_API_URL="https://seu-endpoint.upstash.io"
KV_REST_API_TOKEN="seu-token-aqui"

# Dev local — proxy de /api/* para a URL abaixo durante `npm run dev`
# Use a URL deployada do Vercel para testar com a API real localmente
# Exemplo: VITE_API_URL="https://locavia-dashboard.vercel.app"
# Deixe em branco para usar http://localhost:3000 (vercel dev)
VITE_API_URL=""
